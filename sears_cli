def cmd_experiments_create(args):
    cfg = load_config()
    # Get user's profile to find lab_id and profile.id
    pr = requests.get(
        f"{SUPABASE_URL}/rest/v1/profiles?user_id=eq.{cfg['user_id']}&select=id,lab_id",
        headers=auth_headers(),
    )
    if not pr.ok or not pr.json():
        sys.exit("Could not fetch your profile.")
    profile = pr.json()[0]
    if not profile.get("lab_id"):
        sys.exit("You are not assigned to a lab. Cannot create experiments.")

    # Build experiment payload — field names must match the web app schema
    import datetime
    metadata = {
        "experiment_name": args.title,
        "experiment_dt": datetime.date.today().isoformat(),
    }
    if args.objective:
        metadata["description"] = args.objective
    if args.protocol:
        metadata["protocol"] = args.protocol

    payload = {
        "lab_id": profile["lab_id"],
        "scientist_id": profile["id"],
        "metadata": metadata,
        "status": "draft",
    }

    r = requests.post(
        f"{SUPABASE_URL}/rest/v1/experiments",
        headers={**auth_headers(), "Prefer": "return=representation"},
        json=payload,
    )
    if not r.ok:
        sys.exit(f"Create failed: {r.text}")
    exp = r.json()[0]
    exp_id = exp["id"]
    print(f"✓ Created experiment {exp_id}")

    # Create all measurement sections for this experiment
    sections = list(UNIT_HINTS.keys())
    section_payload = [{"experiment_id": exp_id, "section_type": s} for s in sections]
    sr = requests.post(
        f"{SUPABASE_URL}/rest/v1/measurement_sections",
        headers={**auth_headers(), "Prefer": "return=minimal"},
        json=section_payload,
    )
    if not sr.ok:
        print(f"Warning: section creation failed: {sr.text}")
    else:
        print(f"✓ Created {len(sections)} measurement sections")

    print(f"\nNext step:")
    print(f"  sears upload {exp_id} <section-type> <file>")

